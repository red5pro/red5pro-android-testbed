<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Join Section (Initially Visible) -->
    <LinearLayout
        android:id="@+id/joinLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join Conference"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="32dp"/>

        <RelativeLayout
            android:id="@+id/lobbyPreviewContainer"
            android:layout_width="200dp"
            android:layout_height="250dp">
            <RelativeLayout
                android:visibility="gone"
                android:translationZ="10dp"
                android:id="@+id/lobbyLocalPreviewBlackOverlay"
                android:background="#000"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:textSize="16sp"
                    android:layout_centerInParent="true"
                    android:textColor="#ffffff"
                    android:text="Camera Off"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </RelativeLayout>
            <net.red5.android.core.Red5Renderer
                android:id="@+id/localVideoRendererForPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </RelativeLayout>
        <LinearLayout
            android:id="@+id/lobbyButtonContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <Button
                android:id="@+id/lobbyToggleCameraButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Camera On"
                android:textStyle="bold" />
            <Button
                android:id="@+id/lobbyToggleMicButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mic On"
                android:textStyle="bold" />
            <Button
                android:id="@+id/lobbySwitchCameraButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Switch"
                android:textStyle="bold" />

        </LinearLayout>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Room ID"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/roomIdInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Enter room ID"
            android:inputType="text"
            android:maxLines="1"
            android:padding="12dp"
            android:background="@drawable/edit_text_background"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="User Name"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/userNameInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Enter user name"
            android:inputType="text"
            android:maxLines="1"
            android:padding="12dp"
            android:background="@drawable/edit_text_background"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/joinButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Join Conference"
            android:textSize="16sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Conference Section (Initially Hidden) -->
    <RelativeLayout
        android:id="@+id/conferenceLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Status Info Container -->
        <LinearLayout
            android:id="@+id/statusInfoContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:layout_alignParentTop="true">

            <!-- Status Indicator -->
            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Connected"
                android:textSize="14sp"
                android:textColor="#4CAF50"/>

            <LinearLayout
                android:visibility="gone"
                android:id="@+id/roomIdParticipantContainer"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <!-- Room ID -->
                <TextView
                    android:id="@+id/roomIdText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Room ID: "
                    android:textSize="13sp"
                    android:textColor="#666666" />

                <!-- Participant Count -->
                <TextView
                    android:id="@+id/participantCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Participants: 0"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Local Video Section -->
        <RelativeLayout
            android:translationZ="100dp"
            android:id="@+id/localVideoSection"
            android:layout_width="150dp"
            android:layout_height="225dp"
            android:layout_below="@id/statusInfoContainer"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="8dp">

            <RelativeLayout
                android:visibility="gone"
                android:translationZ="10dp"
                android:id="@+id/localPreviewBlackOverlay"
                android:background="#000"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:layout_centerInParent="true"
                    android:textColor="#fff"
                    android:textSize="16sp"
                    android:text="Camera Off"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </RelativeLayout>

            <net.red5.android.core.Red5Renderer
                android:id="@+id/localVideoRenderer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <TextView
                android:id="@+id/localUserNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You"
                android:translationZ="11dp"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="#80000000"
                android:padding="8dp"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="8dp"/>

        </RelativeLayout>

        <!-- Participants Grid (No ScrollView, fixed 2x2 grid) -->
        <LinearLayout
            android:id="@+id/participantsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/localVideoSection"
            android:layout_above="@id/paginationContainer"
            android:orientation="vertical"
            android:gravity="center">

            <GridLayout
                android:id="@+id/participantsGridLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:padding="8dp" />

        </LinearLayout>

        <!-- Pagination Controls -->
        <LinearLayout
            android:id="@+id/paginationContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@id/conferenceButtonContainer"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone">

            <Button
                android:id="@+id/prevPageButton"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="←"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/pageIndicatorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Page 1 of 1"
                android:textSize="10sp"
                android:textColor="#666666"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:gravity="center"/>

            <Button
                android:id="@+id/nextPageButton"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="→"
                android:textSize="12sp"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/conferenceButtonContainer"
            android:layout_alignParentBottom="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <Button
                android:id="@+id/toggleCameraButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cam On"
                android:textSize="16sp"
                android:textStyle="bold" />
            <Button
                android:id="@+id/toggleMicButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mic On"
                android:textStyle="bold" />
            <Button
                android:id="@+id/switchCameraButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Switch"
                android:textStyle="bold" />
            <Button
                android:id="@+id/leaveButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Leave"
                android:textStyle="bold"
                android:backgroundTint="#F44336"/>
        </LinearLayout>

    </RelativeLayout>

</RelativeLayout>